# WeChef — .gitignore

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/
dist/
build/

# ── Base de données locale ───────────────────────────────────────────────
# Ne PAS versionner la base SQLite : elle contient des données
# persistantes locales qui NE doivent PAS être écrasées par un checkout.
recipes.db
.recipes.db
*.db-shm
*.db-wal

# ── Images générées ─────────────────────────────────────────────────────
# Les images téléchargées depuis Unsplash/Picsum sont stockées localement
# dans static/images/ — ne pas les versionner.
static/images/

# ── Secrets ────────────────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── IDE / OS ────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Logs ────────────────────────────────────────────────────────────────────
*.log
logs/
